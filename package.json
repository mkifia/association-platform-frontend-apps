{
  "name": "@association-platform/frontend-apps",
  "version": "3.0.1",
  "description": "Frontend applications for Association Platform",
  "private": true,
  "workspaces": [
    "member-portal",
    "operator-dashboard",
    "association-dashboard"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm run dev -w member-portal\" \"npm run dev -w operator-dashboard\" \"npm run dev -w association-dashboard\"",
    "start": "npm run start --workspaces",
    "lint": "npm run lint --workspaces",
    "lint:fix": "npm run lint:fix --workspaces",
    "type-check": "npm run type-check --workspaces",
    "test": "npm run test --workspaces",
    "test:e2e": "npm run test:e2e --workspaces",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "install:all": "npm install && npm install --workspaces",
    "build:docker": "docker-compose -f docker-compose.frontend.yml build",
    "start:docker": "docker-compose -f docker-compose.frontend.yml up -d",
    "stop:docker": "docker-compose -f docker-compose.frontend.yml down",
    "logs": "docker-compose -f docker-compose.frontend.yml logs -f",
    "health-check": "npm run health-check --workspaces",
    "storybook": "npm run storybook --workspaces",
    "build-storybook": "npm run build-storybook --workspaces"
  },
  "devDependencies": {
    "@next/eslint-config-next": "^14.0.0",
    "@types/node": "^18.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.0",
    "eslint": "^8.42.0",
    "eslint-config-next": "^14.0.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "postcss": "^8.4.24",
    "prettier": "^2.8.8",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.15",
    "@heroicons/react": "^2.0.18",
    "@hookform/resolvers": "^3.1.1",
    "@next/font": "^14.0.0",
    "@tanstack/react-query": "^4.29.19",
    "@tanstack/react-query-devtools": "^4.29.19",
    "clsx": "^1.2.1",
    "framer-motion": "^10.12.18",
    "next": "^14.0.0",
    "next-auth": "^4.22.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.45.1",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.7.2",
    "zod": "^3.21.4",
    "zustand": "^4.3.9"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "nextjs",
    "react",
    "frontend",
    "association-platform",
    "dashboard",
    "portal"
  ],
  "author": "Association Platform Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/association-platform/frontend-apps.git"
  },
  "bugs": {
    "url": "https://github.com/association-platform/frontend-apps/issues"
  },
  "homepage": "https://github.com/association-platform/frontend-apps#readme"
}
